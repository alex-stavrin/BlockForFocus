{
  "manifest_version": 3,
  "name": "BlockForFocus",
  "version": "1.0",
  "description": "A premium study session tracker and website blocker.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "BlockForFocus",
    "default_icon": {
      "16": "logo_16.png",
      "48": "logo_48.png",
      "128": "logo_128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "logo_16.png",
    "48": "logo_48.png",
    "128": "logo_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.css",
        "blocked.js",
        "logo.png",
        "logo_16.png",
        "logo_48.png",
        "logo_128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
